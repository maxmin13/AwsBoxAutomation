{
  "name": "aws-box-automation",
  "version": "1.0.0",
  "description": "Electron GUI for AwsBoxAutomation",
  "main": "electron/main.js",
  "scripts": {
    "build": "vite build",
    "start": "npm run build && cross-env NODE_ENV=production env -u ELECTRON_RUN_AS_NODE electron .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.awsboxautomation",
    "productName": "AwsBox Automation",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../config",
        "to": "config"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1065.0"
  }
}
